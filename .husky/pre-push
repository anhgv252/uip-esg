#!/usr/bin/env sh
# Auto-check: frontend TypeScript compiles & API types are up to date

cd "$(git rev-parse --show-toplevel)/frontend"

echo "→ TypeScript type-check..."
npm run type-check || { echo "❌ Type check failed — fix TypeScript errors before push"; exit 1; }

echo "→ Checking API contract drift..."
npm run generate:types
if ! git diff --exit-code src/generated/api-types.ts > /dev/null 2>&1; then
  echo "❌ api-types.ts is out of sync with openapi.json"
  echo "   Run: cd frontend && npm run generate:types"
  echo "   Then commit both docs/api/openapi.json and src/generated/api-types.ts"
  exit 1
fi

echo "✅ Pre-push checks passed"
