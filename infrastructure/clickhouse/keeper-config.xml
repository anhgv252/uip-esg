<clickhouse>
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-keeper/clickhouse-keeper-server.log</log>
        <errorlog>/var/log/clickhouse-keeper/clickhouse-keeper-server.err.log</errorlog>
        <size>1000M</size>
        <count>3</count>
    </logger>

    <listen_host>0.0.0.0</listen_host>
    <tcp_port>9181</tcp_port>

    <keeper_server>
        <server_id>1</server_id>
        <storage_dir>/keeper/data</storage_dir>
        <log_storage_dir>/keeper/txn-log</log_storage_dir>

        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>information</raft_logs_level>
        </coordination_settings>

        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>clickhouse-keeper</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
