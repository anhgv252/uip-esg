<!--
  ClickHouse mTLS overlay (MVP5 Sprint 1 - T09 / GAP-046)
  ============================================================================
  Adds an HTTPS listener on port 8443 with mutual-TLS verification:
    - server presents server.crt (signed by internal ca.crt)
    - client must present client.crt signed by the same CA => mTLS

  This file is mounted at /etc/clickhouse-server/config.d/tls-config.xml on
  clickhouse-01 and clickhouse-02 (see docker-compose.ha.yml).

  Coexists with the existing 8123 plain HTTP listener defined in node-config.xml.
  Decision (T09): keep 8123 plain listener for in-cluster operator / Keeper /
  Flink-submitter traffic that is not yet mTLS-wired; the JDBC consumers
  (analytics-service, backend) use 8443 exclusively. Flink submitters and
  forecast-service remain on 8123 for now and are flagged as follow-up in the
  runbook. The plain listener is bound to the container network only
  (no host port publishes 8123 to the host for the HA nodes), so external
  exposure is already constrained.

  Single-region only (ADR-048). No DR cert replication.
-->
<clickhouse>
    <!-- HTTPS listener - mTLS (verify client cert against ca.crt) -->
    <https_port>8443</https_port>
    <!-- Secure native protocol - mTLS (used by: clickhouse-client with secure flag) -->
    <tcp_port_secure>9440</tcp_port_secure>

    <openSSL>
        <server>
            <!-- Server cert + key (presented to client during TLS handshake) -->
            <certificateFile>/etc/clickhouse-server/tls/server.crt</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/tls/server.key</privateKeyFile>

            <!-- Verify client cert => mTLS. invalidity_policy defaults to
                 "reject" - connections without a valid client cert are dropped. -->
            <caConfig>/etc/clickhouse-server/tls/ca.crt</caConfig>
            <verificationMode>strict</verificationMode>
            <loadDefaultCAFile>false</loadDefaultCAFile>
            <cacheSessions>true</cacheSessions>
            <disableProtocols>sslv2,sslv3,tls1.0,tls1.1</disableProtocols>
            <preferServerCiphers>true</preferServerCiphers>
        </server>
    </openSSL>

    <!--
      mTLS transport auth note (M5-1-T09):
      We intentionally do NOT enable <client_certificate_auth> CN->user mapping.
      CH 23.8 with client_certificate_auth forces cert-based user auth and rejects
      the JDBC driver's username/password credentials (AUTHENTICATION_FAILED 516),
      even though mTLS transport verification (openSSL caConfig strict) already
      guarantees only ca-signed clients can connect. Keeping user auth on the
      standard CLICKHOUSE_USER/CLICKHOUSE_PASSWORD path (sent over the mTLS
      channel) is simpler and avoids the cert-auth / password-auth conflict.
      mTLS = transport-layer trust (no ca-signed cert = connection dropped before
      auth); RowPolicy tenant isolation (V32) enforces scoping at SQL layer.
    -->
</clickhouse>
