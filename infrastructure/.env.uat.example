# ============================================================
# UIP Smart City — UAT Environment Variables
# Copy to .env.uat and set real values before running make uat-up
# ============================================================
#
# SECURITY: NEVER commit .env.uat to git.
# Use strong, unique passwords — these credentials are shared
# with the city authority demo team.
# ============================================================

# ── TimescaleDB / PostgreSQL ─────────────────────────────────
POSTGRES_USER=uip_uat
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_min16chars
POSTGRES_DB=uip_smartcity_uat

# ── Kafka (KRaft mode) ───────────────────────────────────────
# Cluster ID must be a valid 22-char base64-encoded UUID (no padding).
# Generate: python3 -c "import base64,uuid; print(base64.b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=VUFUVUlESUQxMjM0NTY3OA
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── EMQX ─────────────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_emqx_dashboard_password
EMQX_NODE_NAME=emqx@emqx

# ── Spring Boot ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_jwt_secret_must_be_at_least_64_hex_chars_for_hmac_sha512_used_in_uat
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=28800000

# ── Claude API (AI Workflow scenarios) ──────────────────────
# Required for AI decision scenarios (AQI analysis, flood routing)
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-CHANGE_ME

# ── Frontend URLs ────────────────────────────────────────────
# Set to the UAT server's IP or hostname as seen by demo participants
# Example: http://192.168.1.100:8080  or  http://uat.smartcity.example.vn:8080
VITE_API_BASE_URL=http://localhost:8080
VITE_SSE_BASE_URL=http://localhost:8080

# ── Demo Login Credentials (for UAT-GUIDE reference) ────────
# These are seeded by Flyway migrations and seed_uat_data.py
# Passwords: admin_Dev#2026!  /  operator_Dev#2026!  /  citizen_Dev#2026!
# DO NOT change these passwords here — they are BCrypt-hashed in Flyway V1/V9
