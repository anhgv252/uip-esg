# ===================================
# UIP Smart City — Environment Variables
# Copy to .env and fill in values
# ===================================

# --- TimescaleDB / PostgreSQL ---
POSTGRES_USER=uip
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=uip_smartcity
TIMESCALEDB_IMAGE=timescale/timescaledb:2.13.1-pg15

# --- Kafka (KRaft mode) ---
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Redis ---
REDIS_PASSWORD=changeme_redis_password

# --- EMQX ---
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=changeme_emqx_password
EMQX_NODE_NAME=emqx@emqx

# --- ClickHouse (Tier 2 OLAP) ---
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Spring Boot ---
JWT_SECRET=changeme_jwt_secret_must_be_at_least_256_bits_long_for_hmac_sha256
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
SPRING_PROFILES_ACTIVE=docker

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
VITE_SSE_BASE_URL=http://localhost:8080

# --- Kong API Gateway ---
# KONG_JWT_SECRET tự động lấy từ JWT_SECRET — không cần set riêng trong docker-compose
# (docker-compose truyền KONG_JWT_SECRET: ${JWT_SECRET})

# --- Keycloak (non-prod, dev mode) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_Dev#2026!
# Realm: uip | Client: uip-api | Secret: uip-api-secret-dev
# Users: operator-hcm / Operator#2026! | admin-aggregator / Admin#2026!

# --- MinIO (S3-compatible storage for Flink checkpoints) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Console: http://localhost:9001
# Bucket auto-created: uip-flink-checkpoints
