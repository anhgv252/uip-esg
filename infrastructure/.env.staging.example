# ============================================================
# UIP Smart City — Staging Environment Variables (TEMPLATE)
# Copy to .env.staging and fill in values before running make staging-up
#
# SECURITY: NEVER commit .env.staging to git.
# Use strong, unique passwords — different from dev and UAT.
# Quick generate all: ./scripts/generate-passwords.sh > .env.generated
# ============================================================

# ── TimescaleDB / PostgreSQL ─────────────────────────────────
POSTGRES_USER=uip_staging
POSTGRES_PASSWORD=                          # Generate: openssl rand -base64 32 | head -c 32
POSTGRES_DB=uip_smartcity_staging

# ── Kafka (KRaft mode) ───────────────────────────────────────
# Generate: python3 -c "import base64,uuid; print(base64.b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=U1RBR0lOR0lEMTIzNDU2Nzg
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=                             # Generate: openssl rand -base64 32 | head -c 32

# ── EMQX ─────────────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=                   # Generate: openssl rand -base64 32 | head -c 32
EMQX_NODE_NAME=emqx@emqx

# ── ClickHouse ───────────────────────────────────────────────
# IMPORTANT: CLICKHOUSE_DB MUST be "analytics" — canonical name used by Flink, analytics-service, and monitoring.
# Changing this will cause silent disconnects between Flink sinks and analytics queries.
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Spring Boot / JWT ────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=28800000

# Sprint 11 capability flags are set in docker-compose.staging.yml via SPRING_APPLICATION_JSON.
# Do NOT set them here — the compose overlay owns this configuration to prevent drift.

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=                   # Generate: openssl rand -base64 32 | head -c 32

# External issuer URL used in JWT iss claim AND in kong.staging.yml jwt_secrets.key.
# These MUST match exactly. Verify with: decode a staging JWT at jwt.io and check the iss field.
JWT_KEYCLOAK_ISSUER=https://staging-api.uip-smartcity.vn/realms/uip
JWT_KEYCLOAK_JWK_SET_URI=https://staging-api.uip-smartcity.vn/realms/uip/protocol/openid-connect/certs
KEYCLOAK_AUTH_SERVER_URL=https://staging-api.uip-smartcity.vn/realms/uip
JWT_HMAC_ISSUER=uip-legacy

# ── MinIO (S3 for Flink checkpoints — NEVER use local disk) ──
MINIO_ROOT_USER=uip-minio
MINIO_ROOT_PASSWORD=                       # Generate: openssl rand -base64 32 | head -c 32

# ── Claude API (AI Workflow scenarios) ───────────────────────
CLAUDE_API_KEY=

# ── Frontend URLs ────────────────────────────────────────────
VITE_API_BASE_URL=https://staging-api.uip-smartcity.vn
VITE_SSE_BASE_URL=https://staging-api.uip-smartcity.vn

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=                    # Generate: openssl rand -base64 32 | head -c 32

# ── gRPC (analytics-service internal) ────────────────────────
# Only relevant for gRPC adapter verification smoke test.
GRPC_ANALYTICS_ADDRESS=static://analytics-service:9090

# ── Application users (pilot defaults) ──────────────────────
ADMIN_PASSWORD=                            # Generate: openssl rand -base64 32 | head -c 32
OPERATOR_PASSWORD=                         # Generate: openssl rand -base64 32 | head -c 32
CITIZEN_PASSWORD=                          # Generate: openssl rand -base64 32 | head -c 32

# ═══════════════════════════════════════════════════════════════
# Push Notification Credentials (P0-1 — MVP4 Sprint 1)
# ═══════════════════════════════════════════════════════════════

# ── FCM (Firebase Cloud Messaging) ──────────────────────────
# Set to "true" to enable FCM adapter (FcmAdapter.java)
PUSH_FCM_ENABLED=true
# Path to Firebase Admin SDK service account JSON file.
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Mount into backend container at the path specified below.
FCM_SERVICE_ACCOUNT_KEY=/opt/uip/secrets/firebase-adminsdk.json

# ── APNs (Apple Push Notification service) ──────────────────
# Set to "true" to enable APNs adapter (ApnsAdapter.java)
PUSH_APNS_ENABLED=true
# Path to APNs .p8 authentication key (PKCS8 format).
# Obtain from: Apple Developer > Certificates, Identifiers & Profiles > Keys > APNs
APNS_CERTIFICATE_PATH=/opt/uip/secrets/apns-auth-key.p8
# Password for the certificate (empty for .p8 token-based auth)
APNS_CERTIFICATE_PASSWORD=
# Apple Team ID (10-character, from Apple Developer > Membership)
APNS_TEAM_ID=                              # e.g. ABCDE12345
# APNs Key ID (10-character, from Apple Developer > Keys)
APNS_KEY_ID=                               # e.g. FGHIJ67890
# App bundle identifier (must match iOS app's bundleIdentifier in app.json)
APNS_TOPIC=com.uip.operatormobile
# Set to "true" for production, "false" for sandbox/development
APNS_PRODUCTION=false

# ── VAPID (Web Push — browser push notifications) ───────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@uip-smartcity.vn

# ── Mobile (EAS Build config reference) ──────────────────────
# Set apiBaseUrl in eas.json to: https://staging-api.uip-smartcity.vn
# The mobile build itself is not controlled by Docker Compose.
