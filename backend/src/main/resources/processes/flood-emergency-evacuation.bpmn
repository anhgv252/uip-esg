<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_3"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="aiC03_floodEmergencyEvacuation" name="AI-C03: Flood Emergency and Evacuation" isExecutable="true">
    <bpmn:startEvent id="StartEvent_3" name="Flood Detected">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_AIAnalysis" name="AI Severity Assessment" camunda:delegateExpression="${aiAnalysisDelegate}">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_1" name="Critical?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_Evacuate" name="Trigger Evacuation" camunda:delegateExpression="${floodEvacuationDelegate}">
      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_3" name="Evacuation Completed">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_3" targetRef="Task_AIAnalysis"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AIAnalysis" targetRef="Gateway_1"/>
    <bpmn:sequenceFlow id="Flow_3_Yes" name="Yes" sourceRef="Gateway_1" targetRef="Task_Evacuate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${aiSeverity == 'CRITICAL'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="Gateway_1" targetRef="EndEvent_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${aiSeverity != 'CRITICAL'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Evacuate" targetRef="EndEvent_3"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="aiC03_floodEmergencyEvacuation">
      <bpmndi:BPMNShape id="shape_StartEvent_3" bpmnElement="StartEvent_3">
        <dc:Bounds x="180" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_Task_AIAnalysis" bpmnElement="Task_AIAnalysis">
        <dc:Bounds x="280" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_Gateway_1" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="445" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_Task_Evacuate" bpmnElement="Task_Evacuate">
        <dc:Bounds x="560" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_EndEvent_3" bpmnElement="EndEvent_3">
        <dc:Bounds x="722" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="216" y="218" />
        <di:waypoint x="280" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="380" y="218" />
        <di:waypoint x="445" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_Flow_3_Yes" bpmnElement="Flow_3_Yes">
        <di:waypoint x="495" y="218" />
        <di:waypoint x="560" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_Flow_3_No" bpmnElement="Flow_3_No">
        <di:waypoint x="470" y="243" />
        <di:waypoint x="470" y="300" />
        <di:waypoint x="740" y="300" />
        <di:waypoint x="740" y="236" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="660" y="218" />
        <di:waypoint x="722" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
