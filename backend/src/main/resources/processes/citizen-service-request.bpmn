<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_2"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="aiC02_citizenServiceRequest" name="AI-C02: Citizen Service Request" isExecutable="true">
    <bpmn:startEvent id="StartEvent_2" name="Request Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:serviceTask id="Task_AIAnalysis" name="AI Classification" camunda:delegateExpression="${aiAnalysisDelegate}">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="Task_Route" name="Route to Department" camunda:delegateExpression="${citizenServiceRequestDelegate}">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:endEvent id="EndEvent_2" name="Request Routed">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_2" targetRef="Task_AIAnalysis"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AIAnalysis" targetRef="Task_Route"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Route" targetRef="EndEvent_2"/>
  </bpmn:process>
</bpmn:definitions>
