# OS / editor
.DS_Store
.vscode/
.idea/
.claude/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files
.env
.env.*
!.env.example
!.env.staging.example
!.env.uat.example
!.env.security.example

# Secrets (push notification credentials, service account keys)
infrastructure/secrets/*.json
infrastructure/secrets/*.p8
infrastructure/secrets/*.jks
infrastructure/secrets/*.keystore
!infrastructure/secrets/README.md

# MVP5 — ClickHouse mTLS private keys (generated locally, NEVER commit)
# Public certs (.crt) are committed; private keys (.key) must stay local.
infrastructure/clickhouse/tls/*.key
# Keep .cnf (openssl config) and .crt (public) tracked
!infrastructure/clickhouse/tls/*.cnf

# Backend (Gradle / Java)
backend/.gradle/
backend/build/
backend/out/
backend/bin/
backend/*.iml

# analytics-service (Gradle / Java)
analytics-service/.gradle/
analytics-service/build/
analytics-service/out/
analytics-service/bin/
applications/analytics-service/.gradle/
applications/analytics-service/build/
applications/analytics-service/out/
applications/analytics-service/bin/

# iot-ingestion-service (Gradle / Java)
applications/iot-ingestion-service/.gradle/
applications/iot-ingestion-service/build/
applications/iot-ingestion-service/out/
applications/iot-ingestion-service/bin/
*.jar
*.war

# Runtime / monitoring artifacts
tests/performance/shadow-monitor.pid
tests/performance/shadow-validation-log.txt

# Flink jobs (Maven)
flink-jobs/target/
flink-jobs/.mvn/wrapper/maven-wrapper.jar

# Frontend (Node / Vite)
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
frontend/.cache/
frontend/targeted-jest-report.json

# java-grapth
.java-graph/
.java-graph.yaml
.mcp.json

# Python caches (poc scripts)
__pycache__/
*.pyc

# Temporary files
*.tmp
*.swp
nohup.out

# Root node_modules (if any)
node_modules/

# Playwright artifacts
frontend/test-results/
frontend/playwright-report/
frontend/storybook-static/
.codegraph/
infrastructure/docker-compose.override.yml

# MVP5 — local build output & JMeter dumps (not source)
target/
*.jtl
g5-rerun-ha-smoke.json
BOOT-INF/
