{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"forecast-service\"}", "legendFormat": "forecast-service" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_total{job=\"forecast-service\"}[5m])", "legendFormat": "req/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "p95 Latency (cached)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/api/v1/forecast/energy\"}[5m])) by (le))", "legendFormat": "p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "ARIMA Fit p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(forecast_arima_fit_seconds_bucket[10m])) by (le))", "legendFormat": "ARIMA fit p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(forecast_cache_hits_total[5m])", "legendFormat": "cache hits/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Fallback Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 12 },
      "targets": [
        { "expr": "rate(forecast_fallback_total[5m])", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "MAPE per Building",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "forecast_arima_mape_ratio", "legendFormat": "{{tenant_id}}/{{building_id}}", "format": "table", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "title": "Error Rate 5xx",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"forecast-service\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"forecast-service\"}[5m]))", "legendFormat": "5xx rate" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["uip", "forecast", "sprint4"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "UIP Forecast Service",
  "uid": "uip-forecast",
  "version": 1
}
