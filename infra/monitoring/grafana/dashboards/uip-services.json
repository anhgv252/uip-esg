{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"uip-backend\"}[5m]))", "legendFormat": "backend" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"analytics-service\"}[5m]))", "legendFormat": "analytics-service" },
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\"}[5m]))", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"uip-backend\"}[5m])) by (le))", "legendFormat": "backend p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"analytics-service\"}[5m])) by (le))", "legendFormat": "analytics p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(kong_latency_seconds_bucket{job=\"kong\"}[5m])) by (le))", "legendFormat": "kong p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"uip-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"uip-backend\"}[5m]))", "legendFormat": "backend" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"analytics-service\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"analytics-service\"}[5m]))", "legendFormat": "analytics-service" },
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\",status=~\"5..\"}[5m])) / sum(rate(kong_http_requests_total{job=\"kong\"}[5m]))", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Service Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "targets": [
        { "expr": "up{job=\"uip-backend\"}", "legendFormat": "backend" },
        { "expr": "up{job=\"analytics-service\"}", "legendFormat": "analytics" },
        { "expr": "up{job=\"kong\"}", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
        "overrides": []
      }
    },
    {
      "title": "Kong Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\"}[5m])) by (route)", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "BMS Module",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "panels": []
    },
    {
      "title": "BMS Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"bms-adapter\", state=\"closed\"}",
          "legendFormat": "closed"
        },
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"bms-adapter\", state=\"open\"}",
          "legendFormat": "open"
        },
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"bms-adapter\", state=\"half_open\"}",
          "legendFormat": "half_open"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "INACTIVE", "color": "gray" }, "1": { "text": "ACTIVE", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "gray" },
              { "value": 1, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "title": "BMS Circuit Breaker — Call Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 20, "x": 4, "y": 21 },
      "targets": [
        {
          "expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"bms-adapter\", kind=\"successful\"}[5m]))",
          "legendFormat": "successful"
        },
        {
          "expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"bms-adapter\", kind=\"failed\"}[5m]))",
          "legendFormat": "failed"
        },
        {
          "expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"bms-adapter\", kind=\"not_permitted\"}[5m]))",
          "legendFormat": "not_permitted (CB open)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "not_permitted (CB open)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "successful" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      }
    },
    {
      "title": "Sprint 6 — AI Workflow + Flood Alert",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "panels": []
    },
    {
      "title": "Flood Alert Events by Severity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(flood_alert_events_total{severity=\"CRITICAL\"}[5m]))",
          "legendFormat": "CRITICAL (P0)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(flood_alert_events_total{severity=\"HIGH\"}[5m]))",
          "legendFormat": "HIGH (P1)",
          "refId": "B"
        },
        {
          "expr": "sum(increase(flood_alert_events_total{severity=\"WARNING\"}[5m]))",
          "legendFormat": "WARNING (P2)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL (P0)" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HIGH (P1)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING (P2)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "AI Workflow — Decision Routing",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(ai_workflow_decision_total{action=\"AUTO_EXECUTE\"}[5m]))",
          "legendFormat": "AUTO_EXECUTE (>85%)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ai_workflow_decision_total{action=\"OPERATOR_QUEUE\"}[5m]))",
          "legendFormat": "OPERATOR_QUEUE (60-85%)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(ai_workflow_decision_total{action=\"ESCALATE\"}[5m]))",
          "legendFormat": "ESCALATE (<60%)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops/sec",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "AUTO_EXECUTE (>85%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "OPERATOR_QUEUE (60-85%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ESCALATE (<60%)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "AI Workflow Active Definitions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(workflow_definitions_active_total)",
          "legendFormat": "Active Workflows",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 10, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "orientation": "auto"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["uip", "services", "sprint5", "bms", "sprint6", "ai-workflow", "flood-alert"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "UIP Services — SLI Overview",
  "uid": "uip-services",
  "version": 1
}
