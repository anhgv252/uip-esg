{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"uip-backend\"}[5m]))", "legendFormat": "backend" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"analytics-service\"}[5m]))", "legendFormat": "analytics-service" },
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\"}[5m]))", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"uip-backend\"}[5m])) by (le))", "legendFormat": "backend p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"analytics-service\"}[5m])) by (le))", "legendFormat": "analytics p95" },
        { "expr": "histogram_quantile(0.95, sum(rate(kong_latency_seconds_bucket{job=\"kong\"}[5m])) by (le))", "legendFormat": "kong p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"uip-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"uip-backend\"}[5m]))", "legendFormat": "backend" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"analytics-service\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"analytics-service\"}[5m]))", "legendFormat": "analytics-service" },
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\",status=~\"5..\"}[5m])) / sum(rate(kong_http_requests_total{job=\"kong\"}[5m]))", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Service Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "targets": [
        { "expr": "up{job=\"uip-backend\"}", "legendFormat": "backend" },
        { "expr": "up{job=\"analytics-service\"}", "legendFormat": "analytics" },
        { "expr": "up{job=\"kong\"}", "legendFormat": "kong" }
      ],
      "fieldConfig": {
        "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] },
        "overrides": []
      }
    },
    {
      "title": "Kong Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum(rate(kong_http_requests_total{job=\"kong\"}[5m])) by (route)", "legendFormat": "{{route}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["uip", "services", "sprint4"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "UIP Services — SLI Overview",
  "uid": "uip-services",
  "version": 1
